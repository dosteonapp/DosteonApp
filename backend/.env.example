# General
PROJECT_NAME="Dosteon API"
API_V1_STR="/api/v1"

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database connections
# LOCAL / STAGING: use port 5432 (direct) for full Prisma migration support
# PRODUCTION: use port 6543 (pgBouncer pooler) for connection efficiency
# Get both from: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
