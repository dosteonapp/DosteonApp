# frontend/.env.example
# Copy to .env.local for development. Real values are set in the Vercel dashboard.

# Environment identifier — controls EnvironmentBanner and config.ts helpers
# Values: development | staging | production
NEXT_PUBLIC_ENV=development

# Supabase — use the credentials for the matching environment's project
NEXT_PUBLIC_SUPABASE_URL=               # https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # eyJ... (anon/public key — safe to expose)

# Backend proxy — Next.js rewrites /api/v1/* → BACKEND_URL/api/v1/*
# Development:  http://127.0.0.1:8000
# Staging:      https://staging-api.dosteon.com
# Production:   https://api.dosteon.com (or your Render service URL)
BACKEND_URL=http://127.0.0.1:8000

# Feature flags (must be false in staging and production)
NEXT_PUBLIC_USE_MOCKS=false
NEXT_PUBLIC_BYPASS_AUTH=false

# Analytics (optional — leave blank to disable PostHog)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
