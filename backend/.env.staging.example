# backend/.env.staging.example
# Copy to .env.staging and fill in values.
# Real values are set in the Render dashboard — never commit real values.

APP_ENV=staging
DEBUG=false
LOG_LEVEL=INFO

# Rate limits — tighter than dev, same as prod
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_MUTATIONS=120/minute

# Database — staging Supabase project (NOT production)
DATABASE_URL=                    # postgresql://postgres:[STAGING_PW]@db.[STAGING_REF].supabase.co:5432/postgres
DIRECT_URL=                      # same as DATABASE_URL for Supabase

# Supabase — staging project credentials (NOT production keys)
SUPABASE_URL=                    # https://[STAGING_REF].supabase.co
SUPABASE_ANON_KEY=               # staging anon key
SUPABASE_SERVICE_ROLE_KEY=       # staging service role key (NOT production key)

# CORS — staging frontend URL
BACKEND_CORS_ORIGINS=["https://staging.dosteon.com"]

# Auth
AUTH_REDIRECT_URL=https://staging.dosteon.com/auth/callback

# Email — redirect all staging emails to test inbox (configure in notifications.py)
RESEND_API_KEY=                  # optional for staging
RESEND_FROM_EMAIL=               # optional for staging

# Admin
ADMIN_API_KEY=                   # generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
