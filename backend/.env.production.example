# backend/.env.production.example
# Reference for what env vars the production Render service needs.
# Real values live in the Render dashboard — never commit real values.

APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING

# Rate limits
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_MUTATIONS=120/minute

# Database — production Supabase project
DATABASE_URL=                    # postgresql://postgres:[PROD_PW]@db.[PROD_REF].supabase.co:5432/postgres
DIRECT_URL=                      # same as DATABASE_URL for Supabase

# Supabase — production project credentials
SUPABASE_URL=                    # https://[PROD_REF].supabase.co
SUPABASE_ANON_KEY=               # production anon key
SUPABASE_SERVICE_ROLE_KEY=       # production service role key

# CORS — production frontend URL
BACKEND_CORS_ORIGINS=["https://dosteon.com","https://www.dosteon.com"]

# Auth
AUTH_REDIRECT_URL=https://dosteon.com/auth/callback

# Email
RESEND_API_KEY=                  # production Resend API key
RESEND_FROM_EMAIL=               # e.g., noreply@dosteon.com

# Admin
ADMIN_API_KEY=                   # generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
